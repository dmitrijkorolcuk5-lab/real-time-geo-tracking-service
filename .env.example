APP_NAME=real-time-geo-tracking-service
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/geotracking
REDIS_URL=redis://redis:6379/0
API_HOST=0.0.0.0
API_PORT=8000
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
QUEUE_MAXSIZE=10000
BATCH_MAX_SIZE=500
BATCH_FLUSH_INTERVAL_SECONDS=1.0
WEBSOCKET_UPDATE_QUEUE_SIZE=512
WEBSOCKET_ALERT_QUEUE_SIZE=512
